# Backend (FastAPI). Used by Next.js rewrites and server routes — not exposed to the browser.
BACKEND_URL=http://localhost:8000

# Optional: call backend directly from the browser (bypasses rewrites). Local dev only.
# NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (eventtz.com): https://api.eventtz.com or your *.up.railway.app URL (include https://).
# Do NOT set NEXT_PUBLIC_API_URL in production — mobile browsers block cross-site auth cookies.

# Display only — keep in sync with backend BOOKING_SERVICE_FEE_PERCENT (default 5)
NEXT_PUBLIC_BOOKING_SERVICE_FEE_PERCENT=5

