# Backend (FastAPI). Used by Next.js rewrites and server routes — not exposed to the browser.
BACKEND_URL=http://localhost:8000

# Optional: call backend directly from the browser (bypasses rewrites). Local dev only.
# NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (eventtz.com): https://api.eventtz.com or your *.up.railway.app URL (include https://).
# Do NOT set NEXT_PUBLIC_API_URL in production — mobile browsers block cross-site auth cookies.

# Mixpanel (browser). Leave empty locally to disable tracking.
# Project token from Mixpanel → Project Settings → Project Token.
NEXT_PUBLIC_MIXPANEL_TOKEN=
# Required for EU data-residency projects (restart npm run dev after changing):
NEXT_PUBLIC_MIXPANEL_API_HOST=https://api-eu.mixpanel.com
# Optional: set false to silence [mixpanel] console logs in development.
# NEXT_PUBLIC_MIXPANEL_DEBUG=false

