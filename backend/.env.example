# Frontend origins (comma-separated) for credentialed browser requests.
# Local dev — localhost variants (regex in config also allows any localhost port):
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000
#
# Production example (Railway Variables — include www if you use it):
# CORS_ALLOWED_ORIGINS=https://eventtz.com,https://www.eventtz.com,http://localhost:3000,http://127.0.0.1:3000
# FRONTEND_URL=https://eventtz.com

# Base URL of the deployed frontend — Stripe redirects + auto-added to CORS allow list.
FRONTEND_URL=http://localhost:3000

# Supabase — backend only (never ship to frontend)
SUPABASE_URL=
# Project Settings → API → **service_role** (secret JWT, long). Required for backend DB writes.
# Alias: SUPABASE_KEY (prefer setting only one of SUPABASE_SERVICE_ROLE_KEY or SUPABASE_KEY).
SUPABASE_SERVICE_ROLE_KEY=
# Local testing mode: mock in-memory auth, no Supabase calls
LOCAL_AUTH_MODE=false

# Max single vendor surcharge and total surcharge % of line-item subtotal (adjustments)
BOOKING_MAX_ADJUSTMENT_GBP=50000
BOOKING_MAX_ADJUSTMENT_PCT_OF_SUBTOTAL=200

# Media uploads (Supabase Storage)
# Create this bucket in Supabase Storage. Recommend public bucket for images.
MEDIA_IMAGES_BUCKET=eventtz-images
# Max size for video/PDF uploads (bytes). Images have no app-level size limit.
MEDIA_MAX_FILE_UPLOAD_BYTES=50000000

# OpenAI — vendor onboarding (bio generation + portfolio image quality via Responses API)
# and marketplace search query parsing (explore/search). Model ids are fixed in code
# (`app/core/constants.py`); only the API key is configured here.
OPENAI_API_KEY=
# In-memory TTL cache for parsed marketplace queries (seconds; 0 disables cache).
MARKETPLACE_SEARCH_AI_CACHE_TTL_SECONDS=3600
MARKETPLACE_SEARCH_AI_CACHE_MAX_ENTRIES=500

# Base URL of the deployed frontend (Stripe return/refresh/success/cancel URLs)
FRONTEND_URL=http://localhost:3000

# Stripe Connect (vendor payouts, Express accounts) + Checkout (client payments)
# https://dashboard.stripe.com/apikeys — backend only, never expose to the frontend.
#
# IMPORTANT — one Stripe account, many apps:
# If Eventtz shares the same Stripe account (same sk_test_/sk_live_) as another product
# (e.g. OSCE Guide), Stripe sends EVERY checkout event to EVERY webhook endpoint on that
# account. Register a dedicated Eventtz endpoint (below) and use Eventtz-only keys/secrets
# here. Do not paste another app's STRIPE_WEBHOOK_SECRET — each endpoint has its own whsec_.
#
# Recommended: create a separate Stripe account for Eventtz (test + live) so webhooks never
# cross between products.
STRIPE_SECRET_KEY=
#
# Local dev: run `make stripe-webhooks` in a second terminal; paste the CLI whsec_ here.
# Production: Stripe Dashboard → Developers → Webhooks → Add endpoint →
#   https://<eventtz-api-domain>/api/v1/webhooks/stripe
# Events: checkout.session.completed, account.updated
# Use the signing secret from THAT endpoint only (not OSCE Guide or stripe listen from another project).
STRIPE_WEBHOOK_SECRET=

# Post-event completion: hours after the event day ends before the vendor payout is
# released automatically (paid bookings with no open dispute).
BOOKING_PAYOUT_AUTO_RELEASE_HOURS_AFTER_EVENT=48

# UK address lookup (backend only — never expose to frontend; use /api/v1/client/geo/*).
#
# Option A — Ordnance Survey OS Places API (address search). This is NOT the same as "OS Maps API".
# In OS Data Hub: APIs → find "OS Places API" (or "Places") → Add to project → use that project's API key.
# https://osdatahub.os.uk/
OS_PLACES_API_KEY=
#
# Option B — getAddress.io — use if you do not add OS Places (leave OS_PLACES_API_KEY empty).
# https://getaddress.io/
GETADDRESS_API_KEY=

SUPER_ADMIN_EMAILS=hello@fourintegers.com
# Resend transactional email (https://resend.com) — only env var needed for email.
RESEND_API_KEY=

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# true = compact single-line logs; false = detailed dev blocks (stdout + file)
# Railway / cross-origin frontend: set true so auth cookies use Secure + SameSite=None.
IS_PRODUCTION=false
# Relative to backend/ — rotating files: eventtz.log, eventtz.log.1, …
# LOG_DIR=logs
# LOG_FILE_NAME=eventtz.log
# LOG_MAX_BYTES=10000000
# LOG_BACKUP_COUNT=3
